# Shared .env for hardhat and nextjs — sourced by:
#   - nextjs/next.config.ts → dotenv.config({ path: '../.env' })
#   - hardhat/bin/* → . ../.env

NEXT_PUBLIC_APPNAME='Learn through games'
NEXT_PUBLIC_WC_PROJECT_ID='96b178c4484c0b55339aee97c8659881'

# API
NEXT_PUBLIC_API_URL=https://learn.tg:9001/api
NEXT_PUBLIC_API_BASE=https://learn.tg:3500/learntg-admin
NEXT_PUBLIC_API_BUSCA_CURSOS_URL="${NEXT_PUBLIC_API_BASE}/proyectosfinancieros.json"
NEXT_PUBLIC_API_PRESENTA_CURSO_URL="${NEXT_PUBLIC_API_BASE}/proyectosfinancieros/curso_id.json"
NEXT_PUBLIC_API_DESCARGA_URL="${NEXT_PUBLIC_API_BASE}/sis/arch/lang/prefix?descarga=guia.md"
NEXT_PUBLIC_API_USERS="${NEXT_PUBLIC_API_BASE}/usuarios.json"
NEXT_PUBLIC_API_RELIGIONS="${NEXT_PUBLIC_API_BASE}/admin/religiones.json"
NEXT_PUBLIC_API_COUNTRIES="${NEXT_PUBLIC_API_BASE}/admin/paises.json"
NEXT_PUBLIC_API_SHOW_USER="${NEXT_PUBLIC_API_BASE}/usuarios/usuario_id.json"
NEXT_PUBLIC_API_UPDATE_USER="${NEXT_PUBLIC_API_BASE}/usuarios/actualiza_mi_usuario"

NEXT_PUBLIC_RPC_URL="https://forno.celo-sepolia.celo-testnet.org"
BLOCKSCOUT_API_KEY="your-blockscout-api-key"
BASESCAN_API_KEY="your-basescan-api-key"

PRIVATE_KEY="0x..."
NEXT_PUBLIC_ADDRESS="0x..."
NEXT_PUBLIC_USDT_ADDRESS=0x7d7a73c8c0D00Fdf8b54b1a6dB6eBDEcdBa78aE8
NEXT_PUBLIC_USDT_DECIMALS=6
NEXT_PUBLIC_CCOP_ADDRESS=0x5F8d55c3627d2dc0a2B4afa798f877242F382F67
NEXT_PUBLIC_CCOP_DECIMALS=18
NEXT_PUBLIC_GOODDOLLAR_ADDRESS=0xb4fF4DcbaC21ECBe3b0A313aFd031aF7279be142
NEXT_PUBLIC_GOODDOLLAR_DECIMALS=18
NEXT_PUBLIC_CELOUBI_ADDRESS=0x3aDEaCcab1eb79850f4D74535Eb6b2b38eE89660
MOCK_USDT_ADDRESS=0x7d7a73c8c0D00Fdf8b54b1a6dB6eBDEcdBa78aE8

NEXT_PUBLIC_NETWORK=celoSepolia
NEXT_PUBLIC_EXPLORER_TX=https://celo-sepolia.blockscout.com/tx/
NEXT_PUBLIC_SELF_ENDPOINT="https://learn.tg:9001/api/self-verify"

# V3 and SLEARN addresses come from hardhat/deployments/ via lib/deployments.ts

# Running
PORT=4000
OPDEV=""

NEXT_PUBLIC_AUTH_URL=https://learn.tg:9001
NEXTAUTH_URL=https://learn.tg:9001
NEXTAUTH_SECRET=007

# Database
DB_SOCKET=/var/www/var/run/postgresql/
PGHOST=/var/www/var/run/postgresql/
DB_NAME=learntg_des
PGDATABASE=learntg_des
DB_USER=learntg
PGUSER=learntg
DB_PASSWORD=password
PGPASSWORD=password
DATABASE_URL=postgres://$PGUSER:$PGPASSWORD@localhost/$PGDATABASE
