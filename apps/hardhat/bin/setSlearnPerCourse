#!/bin/sh
# Set SLEARN amount per guide (1 SLEARN) for all courses that have a vault.
# Reads DB connection from apps/.env, queries course IDs, calls V3 contract.
set -e
. ../.env

COURSE_IDS=$(PGPASSWORD="$PGPASSWORD" psql -t -A -h "$PGHOST" -d "$PGDATABASE" -U "$PGUSER" -c \
  "SELECT id FROM cor1440_gen_proyectofinanciero ORDER BY id" | paste -sd ' ' -)

if [ -z "$COURSE_IDS" ]; then
  echo "No courses found in DB"
  exit 1
fi

echo "Courses found: $COURSE_IDS"
echo "[ENTER] para continuar"
read

export COURSE_IDS
node_modules/.bin/hardhat run scripts/set-slearn-per-course.ts --network "$NEXT_PUBLIC_NETWORK"
